# Build context when using the repo-root Dockerfile (Root Directory = repository root).
# Keeps uploads small and avoids copying local venv/secrets into the image.

.git
**/.venv
**/__pycache__
**/*.py[cod]
**/.pytest_cache
**/.mypy_cache
**/*.egg-info
**/.env
**/.env.*
!**/.env.example
backend/data/*.db
backend/data/*.db-*
frontend/node_modules
frontend/.next
frontend/out
.DS_Store
